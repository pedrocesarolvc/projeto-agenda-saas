# Modelo de variaveis de ambiente (Etapa 1, secao 1.6).
# Copiar para .env e preencher com valores reais — .env nunca vai pro
# controle de versao, so este .example documenta quais chaves existem.

# Conexao com o unico banco Postgres compartilhado por todos os
# tenants (Etapa 2, secao 2.3-2.4).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projeto_agenda

# Chave de assinatura do JWT (Etapa 3, app/auth/jwt.py). Em producao,
# gerar um valor aleatorio longo (ex.: openssl rand -hex 32) — nunca
# usar o exemplo abaixo fora de desenvolvimento local.
SECRET_KEY=changeme-em-producao-use-uma-chave-longa-e-aleatoria
